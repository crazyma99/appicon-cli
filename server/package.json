{
  "name": "appicon-server",
  "version": "0.1.0",
  "description": "Reference implementation of appicon custom API server with Web UI",
  "type": "module",
  "scripts": {
    "build": "tsup && cd web && npm run build && cp -r dist ../public",
    "build:server": "tsup",
    "build:web": "cd web && npm run build && cp -r dist ../public",
    "start": "node dist/index.js",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
