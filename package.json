{
  "name": "appicon-cli",
  "version": "0.1.0",
  "description": "Search and download APP icons from Apple App Store, Google Play, and custom servers",
  "type": "module",
  "bin": {
    "appicon": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["app-icon", "cli", "apple", "google-play", "figma"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "google-play-scraper": "^9.1.1",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
